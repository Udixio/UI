{
  "name": "@udixio/icons-outlined-400",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./filled": {
      "development": "./src/filled/index.ts",
      "types": "./dist/filled/index.d.ts",
      "import": "./dist/filled/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "tsx ../../../scripts/generate-icons.ts outlined 400",
    "build": "pnpm generate && tsc -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@material-symbols/svg-400": "*",
    "tsx": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Udixio/UI.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}
