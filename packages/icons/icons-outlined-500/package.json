{
  "name": "@udixio/icons-outlined-500",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./filled/*": {
      "development": "./src/*.filled.ts",
      "types": "./dist/*.filled.d.ts",
      "import": "./dist/*.filled.js"
    }
  },
  "scripts": {
    "generate": "tsx ../../../scripts/generate-icons.ts outlined 500",
    "build": "pnpm generate && tsc -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@material-symbols/svg-500": "*",
    "tsx": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Udixio/UI.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}
