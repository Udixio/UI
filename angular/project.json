{
  "name": "angular",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "angular/src",
  "prefix": "udixio",
  "tags": [],
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "angular/ng-package.json",
        "tailwindConfig": "angular/tailwind.config.js"
      },
      "configurations": {
        "production": {
          "tsConfig": "angular/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "angular/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "angular/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "angular/.storybook",
        "browserTarget": "angular:build-storybook",
        "compodoc": false,
        "styles": ["angular/src/index.scss"]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/angular",
        "configDir": "angular/.storybook",
        "browserTarget": "angular:build-storybook",
        "compodoc": false,
        "styles": ["angular/src/index.scss"]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c angular/.storybook --url=http://localhost:4400"
      }
    }
  }
}
